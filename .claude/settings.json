{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run test *)",
			"Bash(gmake build*)",
			"Bash(gmake -C frontend/ build *)",
			"Bash(grep *)",
			"Bash(xargs)",
			"Edit(/**/*.go)",
			"Edit(/frontend/**)",
			"Edit(**/*.md)",
			"Edit(sql/**/*.sql)",
			"Edit(memory/**.md)",
			"Edit(fronted/memory/**.md)"
    ],
    "deny": [
    ]
  },
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
  }
}
